{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window: core IPC + folder picker dialog",
  "windows": ["main", "synapse-*"],
  "permissions": [
    "core:default",
    "core:window:allow-set-theme",
    "core:window:allow-set-title",
    "dialog:default",
    "opener:default",
    "updater:default",
    "process:default",
    "drag:default"
  ]
}
