{
  "name": "synapse",
  "private": true,
  "version": "0.5.17",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "sync:excalidraw-assets": "node scripts/copy-excalidraw-assets.mjs",
    "sync:pdfjs-assets": "node scripts/copy-pdfjs-assets.mjs",
    "sync:assets": "npm run sync:excalidraw-assets && npm run sync:pdfjs-assets",
    "predev": "npm run sync:assets",
    "dev": "vite",
    "prebuild": "npm run sync:assets",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" vite.config.ts --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "ladle": "ladle serve",
    "ladle:build": "ladle build",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri"
  },
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "^2.1.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tiptap/core": "^3.26.0",
    "@tiptap/extension-code-block-lowlight": "^3.26.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.9",
    "lowlight": "^3.3.0",
    "mermaid": "^11.15.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.9.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@ladle/react": "^5.1.1",
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.34.0",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}
